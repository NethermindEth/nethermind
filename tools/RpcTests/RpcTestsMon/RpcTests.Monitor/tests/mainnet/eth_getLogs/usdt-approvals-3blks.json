[
  {
    "run": "EveryBlocks(3)",
    "test": {
      "description": "USDT approvals in 3-blocks range"
    },
    "request": {
      "jsonrpc": "2.0",
      "method": "eth_getLogs",
      "params": [
        {
          "address": "{{Address.USDT}}",
          "fromBlock": "{{Hex(RecentBlock - 2)}}",
          "toBlock": "{{Hex(RecentBlock)}}",
          "topics": [
            [
              "{{Topic.Approval}}"
            ]
          ]
        }
      ],
      "id": "{{Request.Number}}"
    }
  }
]
