[
  {
    "run": "EveryBlock",
    "test": {
      "description": "ERC20 transfers"
    },
    "request": {
      "jsonrpc":"2.0",
      "method":"eth_getLogs",
      "params":[{
        "fromBlock":"{{Hex(RecentBlock)}}",
        "toBlock":"{{Hex(RecentBlock)}}",
        "topics": [
          "{{Topic.Transfer}}"
        ]
      }],
      "id": "{{Request.Number}}"
    }
  }
]
