[
  {
    "run": "EveryBlocks(5)",
    "test": {
      "description": "WETH transfers to Uniswap V3"
    },
    "request": {
      "jsonrpc": "2.0",
      "method": "eth_getLogs",
      "params": [{
        "fromBlock": "{{Hex(RecentBlock - 9)}}",
        "toBlock": "{{Hex(RecentBlock)}}",
        "address": ["{{Address.WETH}}", "{{Address.USDT}}"],
        "topics": [
          "{{Topic.Transfer}}",
          null,
          "0x0000000000000000000000003fc91a3afd70395cd496c647d5a6cc9d4b2b7fad"
        ]
      }],
      "id": "{{Request.Number}}"
    }
  }
]
