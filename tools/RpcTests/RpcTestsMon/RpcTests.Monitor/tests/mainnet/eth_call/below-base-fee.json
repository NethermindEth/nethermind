[
  {
    "run": "EveryBlocks(3)",
    "test": {
      "description": "gasPrice below block base fee - should return fee cap error"
    },
    "request": {
      "jsonrpc": "2.0",
      "method": "eth_call",
      "params": [
        {
          "from": "{{Address.WETH}}",
          "to": "{{Address.Zero}}",
          "gas": "0x5208",
          "gasPrice": "{{Hex(Head.BaseFeePerGas - 1)}}",
          "value": "0x0"
        },
        "{{Hex(RecentBlock)}}"
      ],
      "id": "{{Request.Number}}"
    },
    "response": {
      "id": "{{Request.Number}}",
      "jsonrpc": "2.0",
      "error": null
    }
  }
]
