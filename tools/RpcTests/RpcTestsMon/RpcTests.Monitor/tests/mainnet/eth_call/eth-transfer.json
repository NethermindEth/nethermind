[
  {
    "run": "EveryBlocks(3)",
    "test": {
      "description": "Only eth transfer"
    },
    "request": {
      "jsonrpc": "2.0",
      "method": "eth_call",
      "params": [
        {
          "from": "{{Address.WETH}}",
          "to": "{{Address.Zero}}",
          "gas": "0x5208",
          "gasPrice": "0x2CB417800",
          "value": "0x229322"
        },
        "{{Hex(RecentBlock)}}"
      ],
      "id": "{{Request.Number}}"
    },
    "response": {
      "id": "{{Request.Number}}",
      "jsonrpc": "2.0",
      "result": "0x"
    }
  }
]

