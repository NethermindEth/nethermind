<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <OutputType>Exe</OutputType>
        <TargetFramework>net10.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <RootNamespace>Nethermind.RpcTests.Monitor</RootNamespace>
    </PropertyGroup>

    <ItemGroup>
      <PackageReference Include="DynamicExpresso.Core" />
      <PackageReference Include="Microsoft.Extensions.FileSystemGlobbing" />
      <PackageReference Include="SlackNet" />
      <PackageReference Include="System.CommandLine" />
    </ItemGroup>

    <ItemGroup>
      <ProjectReference Include="../RpcTests.Common/RpcTests.Common.csproj" />
    </ItemGroup>

    <ItemGroup>
      <Using Include="Nethermind.RpcTests.Common" />
    </ItemGroup>

    <ItemGroup>
      <None Update="tests/**/*.json">
        <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      </None>
    </ItemGroup>

</Project>
