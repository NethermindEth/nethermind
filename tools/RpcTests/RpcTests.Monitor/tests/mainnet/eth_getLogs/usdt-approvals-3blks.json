[
  {
    "run": "EveryBlocks(3)",
    "test": {
      "description": "USDT approvals in 3-blocks range"
    },
    "request": {
      "jsonrpc": "2.0",
      "method": "eth_getLogs",
      "params": [
        {
          "address": "0xdAC17F958D2ee523a2206206994597C13D831ec7",
          "fromBlock": "{{Hex(Recent.Number - 2)}}",
          "toBlock": "{{Hex(Recent.Number)}}",
          "topics": [
            [
              "{{Topic.Approval}}"
            ]
          ]
        }
      ],
      "id": "{{Request.Number}}"
    }
  }
]
