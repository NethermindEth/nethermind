+    public void WaitForBalWarmup()
+    {
+        Task? task = _balWarmupTask;
+        if (task is null) return;
+        _balWarmupTask = null;
+
+        try
+        {
+            task.GetAwaiter().GetResult();
+        }
+        catch (OperationCanceledException)
