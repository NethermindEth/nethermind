<?xml version="1.0" encoding="utf-8"?>
<Configuration>
  <DeterministicReport>true</DeterministicReport>
  <IncludeTestAssembly>False</IncludeTestAssembly>
  <ExcludeAssembliesWithoutSources>MissingAll</ExcludeAssembliesWithoutSources>
  <CodeCoverage>
    <CollectFromChildProcesses>True</CollectFromChildProcesses>
    <ModulePaths>
      <Exclude>
        <!-- Test assemblies -->
        <ModulePath>.*[\\/](Ethereum|Nethermind)\..*\.Test(\.Runner)?\.dll$</ModulePath>
        <!-- Test infrastructure / host -->
        <ModulePath>.*[\\/]testhost[^\\/]*\.dll$</ModulePath>
        <ModulePath>.*[\\/]Microsoft\.(Testing\.Platform|TestPlatform|VisualStudio\.TestPlatform)[^\\/]*\.dll$</ModulePath>
      </Exclude>
    </ModulePaths>
    <Attributes>
      <Exclude>
        <Attribute>^System\.CodeDom\.Compiler\.GeneratedCodeAttribute$</Attribute>
        <Attribute>^System\.Diagnostics\.CodeAnalysis\.ExcludeFromCodeCoverageAttribute$</Attribute>
      </Exclude>
    </Attributes>
    <Sources>
      <Exclude>
        <!-- Build output / intermediates -->
        <Source>.*[\\/]artifacts[\\/]obj[\\/].*</Source>
        <Source>.*[\\/]obj[\\/].*</Source>
        <Source>.*[\\/]bin[\\/].*</Source>
        <!-- Generated C# -->
        <Source>.*\.g\.cs$</Source>
        <Source>.*\.generated\.cs$</Source>
        <Source>.*[\\/]Generated[\\/].*</Source>
        <Source>.*[\\/]AssemblyInfo\.cs$</Source>
        <Source>.*[\\/]GlobalUsings\.g\.cs$</Source>
        <Source>.*[\\/]TemporaryGeneratedFile_.*\.cs$</Source>
        <Source>.*[\\/]System\.Text\.RegularExpressions\.Generator[\\/].*</Source>
      </Exclude>
    </Sources>
  </CodeCoverage>
</Configuration>
