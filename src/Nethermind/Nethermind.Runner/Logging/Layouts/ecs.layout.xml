<?xml version="1.0" encoding="utf-8"?>
<!-- ECS (Elastic Common Schema) console layout for —logging-format=ecs.
     See https://www.elastic.co/guide/en/ecs/current/index.html -->
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
  <targets>
    <target name="json-console" xsi:type="Console">
      <layout xsi:type="JsonLayout" suppressSpaces="true">
        <attribute name="@timestamp" layout="${date:universalTime=true:format=yyyy-MM-ddTHH\:mm\:ss.fffffffZ}" />
        <attribute name="log.level" layout="${level:lowercase=true}" />
        <attribute name="message" layout="${replace:searchFor=\x1B\[[0-9;]*m:replaceWith=:regex=true:inner=${message}}" />
        <attribute name="ecs.version" layout="8.11.0" />
        <attribute name="log.logger" layout="${logger}" />
        <attribute name="process.thread.id" layout="${threadid}" encode="false" />
        <attribute name="error.type" layout="${exception:format=type}" includeEmptyValue="false" />
        <attribute name="error.message" layout="${exception:format=message}" includeEmptyValue="false" />
        <attribute name="error.stack_trace" layout="${exception:format=tostring}" includeEmptyValue="false" />
      </layout>
    </target>
  </targets>
  <rules>
    <logger name="*" minlevel="Trace" writeTo="json-console" />
  </rules>
</nlog>
