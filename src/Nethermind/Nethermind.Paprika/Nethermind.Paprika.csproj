<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <AssemblyName>Paprika</AssemblyName>
    <RootNamespace>Paprika</RootNamespace>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <LangVersion>13.0</LangVersion>
    <TreatWarningsAsErrors>false</TreatWarningsAsErrors>
    <NoWarn>$(NoWarn);CS8321;CS8600;CS8601;CS8602;CS8604;CS8618;CS9113</NoWarn>
    <WarningsNotAsErrors>$(WarningsNotAsErrors);CS8321;CS8600;CS8601;CS8602;CS8604;CS8618;CS9113</WarningsNotAsErrors>
    <RunAnalyzersDuringBuild>false</RunAnalyzersDuringBuild>
    <EnforceCodeStyleInBuild>false</EnforceCodeStyleInBuild>
    <EnableDefaultCompileItems>false</EnableDefaultCompileItems>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="..\Paprika\src\Paprika\**\*.cs" />
    <Compile Remove="..\Paprika\src\Paprika\IDb.cs" />
    <Compile Remove="..\Paprika\src\Paprika\Store\RootPage.cs" />
    <Compile Remove="..\Paprika\src\Paprika\Store\StorageFanOut.cs" />
    <Compile Include="Patches\IDb.cs" />
    <Compile Include="Patches\Store\RootPage.cs" />
    <Compile Include="Patches\Store\StorageFanOut.cs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="HdrHistogram" />
    <PackageReference Include="Nethermind.Numerics.Int256" />
    <PackageReference Include="NonBlocking" />
  </ItemGroup>

</Project>
